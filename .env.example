# RPC endpoint for the target testnet (e.g. Alchemy / Infura Sepolia URL)
SEPOLIA_RPC_URL=https://eth-sepolia.g.alchemy.com/v2/YOUR_KEY

# Etherscan API key for contract verification
ETHERSCAN_API_KEY=YOUR_ETHERSCAN_KEY

# NOTE: do NOT put your private key here.
# Import it once into an encrypted keystore instead:
#   cast wallet import deployer --interactive
# then deploy with:  forge script ... --account deployer
